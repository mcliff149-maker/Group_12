# Server
PORT=4000

# CORS – comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# JWT secret (change this in production!)
JWT_SECRET=change_me_in_production

# JWT expiry  (e.g. 1h, 7d)
JWT_EXPIRES_IN=7d

# Data store: "memory" or "file"
DATA_STORE=file

# Directory for JSON files when DATA_STORE=file
# DATA_DIR=./data
